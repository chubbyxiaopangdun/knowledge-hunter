# 知识猎手 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ===========================================
# 知识库同步配置
# ===========================================

## 飞书知识库（可选）
# 是否启用飞书同步（默认关闭）
FEISHU_ENABLED=false

# 飞书知识库空间名称（默认：个人知识库）
FEISHU_WIKI_SPACE=my_library

# 飞书根文件夹（会自动创建子文件夹）
FEISHU_ROOT_FOLDER=内容监控

## Obsidian 知识库（可选）
# 是否启用 Obsidian 同步（默认关闭）
OBSIDIAN_ENABLED=false

# Obsidian vault 路径（必须指定有效的 vault 目录）
# 示例：/Users/username/Documents/ObsidianVault
#        /home/user/obsidian/vault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# vault 内的目标文件夹（会自动创建）
OBSIDIAN_FOLDER=内容监控

# 是否添加 frontmatter 元数据（默认开启）
OBSIDIAN_FRONTMATTER=true

# 文件命名格式：date_title 或 title_date
OBSIDIAN_FILE_NAMING=date_title

# ===========================================
# 平台 API 配置
# ===========================================

## B站配置（可选）
# B站登录态 Cookie（仅访问私密内容需要）
# 强烈建议使用小号，不要使用主账号
# BILIBILI_SESSDATA=your_sessdata_here

## YouTube 配置（可选）
# YouTube Data API Key（用于获取视频信息）
# YOUTUBE_API_KEY=your_api_key_here

## Twitter 配置（可选）
# Twitter API Bearer Token
# TWITTER_BEARER_TOKEN=your_bearer_token_here

## 小宇宙配置（通常不需要配置）
# XIAOYUZHOU_API_KEY=your_api_key_here

# ===========================================
# AI 服务配置（可选）
# ===========================================

## OpenAI（用于观点提取）
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

## DeepSeek（性价比更高）
# DEEPSEEK_API_KEY=sk-your-api-key

## 阿里云通义千问
# QWEN_API_KEY=your-api-key

# ===========================================
# Whisper 配置（本地转录）
# ===========================================

# Whisper 模型大小（tiny/base/small/medium/large）
# 越大越准确，但需要更多显存
WHISPER_MODEL=base

# ===========================================
# 通知配置（可选）
# ===========================================

## 飞书机器人通知
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

## 钉钉机器人通知
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ===========================================
# 金句提取配置 (v1.4.0新增)
# ===========================================

# 是否启用金句提取功能（默认关闭，向后兼容）
ENABLE_QUOTE_EXTRACTION=false

# 每个视频提取的金句数量
QUOTES_PER_VIDEO=20

# 金句提取使用的AI模型（默认gpt-4o-mini，性价比高）
QUOTE_MODEL=gpt-4o-mini

# 素材库存放目录
QUOTES_OUTPUT_DIR=./quotes
